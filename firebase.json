{
    "functions": {
        "source": "functions",
        "runtime": "nodejs20",
        "ignore": [
            "node_modules",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log"
        ]
    },
    "hosting": {
        "headers": [
            {
                "source": "/**",
                "headers": [
                    {
                        "key": "Access-Control-Allow-Origin",
                        "value": "*"
                    },
                    {
                        "key": "Access-Control-Allow-Credentials",
                        "value": "true"
                    },
                    {
                        "key": "Set-Cookie",
                        "value": "SameSite=None; Secure"
                    }
                ]
            }
        ],
        "public": "pti-app/dist/pti-app/browser",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/mcp",
                "function": "mcp"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}
